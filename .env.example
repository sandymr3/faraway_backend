# ── SwarmResQ Backend — environment variables ────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Server binding
HOST=0.0.0.0
PORT=8000

# Comma-separated list of allowed frontend origins.
# Use * to allow all (fine for hackathon, lock down for prod).
# Example: CORS_ORIGINS=https://swarmresq.vercel.app,http://localhost:3000
CORS_ORIGINS=*

# Simulation tick rate (Hz). Lower to reduce CPU on cheap hosting.
TICK_HZ=30
